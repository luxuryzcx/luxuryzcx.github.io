<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>MCP on 1ux4ry Archive</title><link>https://luxuryzcx.github.io/categories/mcp/</link><description>Recent content in MCP on 1ux4ry Archive</description><generator>Hugo</generator><language>zh-cn</language><lastBuildDate>Mon, 15 Jun 2026 23:28:25 +0800</lastBuildDate><atom:link href="https://luxuryzcx.github.io/categories/mcp/index.xml" rel="self" type="application/rss+xml"/><item><title>codex上搭建kali mcp 文件</title><link>https://luxuryzcx.github.io/posts/codex%E4%B8%8A%E6%90%AD%E5%BB%BAkali-mcp-%E6%96%87%E4%BB%B6/</link><pubDate>Mon, 15 Jun 2026 23:28:25 +0800</pubDate><guid>https://luxuryzcx.github.io/posts/codex%E4%B8%8A%E6%90%AD%E5%BB%BAkali-mcp-%E6%96%87%E4%BB%B6/</guid><description>&lt;p&gt;项目地址&lt;/p&gt;
&lt;p&gt;&lt;a href="https://github.com/Wh0am123/MCP-Kali-Server"&gt;https://github.com/Wh0am123/MCP-Kali-Server&lt;/a&gt;&lt;/p&gt;
&lt;p&gt;文件架构&lt;/p&gt;
&lt;p&gt;&lt;figure class="content-figure"&gt;
 &lt;img
 src="https://luxury-1393333723.cos.ap-nanjing.myqcloud.com//img/20260422172441982.png"
